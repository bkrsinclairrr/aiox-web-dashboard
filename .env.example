# 🔐 SUPABASE Configuration
# Get these from: supabase.com → Your Project → Settings → API
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# 🤖 AIOX Engine Configuration  
# Point to your AIOX Core instance (local or remote)
# For PRODUCTION: use a stable public URL
# For DEVELOPMENT: http://localhost:4002
VITE_AIOX_ENGINE_URL=http://localhost:4002

# 📁 AIOX Project Root (optional)
# Only needed if running AIOX locally
VITE_AIOX_PROJECT_ROOT=/path/to/aiox-core

# 🎨 App Configuration (optional)
VITE_APP_NAME=AIOX Dashboard
VITE_THEME=aiox
VITE_DEBUG=false
